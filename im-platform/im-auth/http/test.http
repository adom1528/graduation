### 变量设置 (可选，方便以后改)
@host = http://localhost:9000

# ==========================================
# 场景 1: 正常注册一个新用户
# ==========================================
POST {{host}}/im-auth/auth/register
Content-Type: application/x-www-form-urlencoded

username=userA&password=123456

###

# ==========================================
# 场景 2: 再次注册相同的用户 (预期报错)
# ==========================================
POST {{host}}/im-auth/auth/register
Content-Type: application/x-www-form-urlencoded

username=ww&password=12345

###
# ==========================================
# 场景 3: 用户登录 (获取 Token)
# ==========================================
POST {{host}}/im-auth/auth/login
Content-Type: application/x-www-form-urlencoded

username=gemini_user&password=123456
###

POST {{host}}/im-auth/auth/login
Content-Type: application/x-www-form-urlencoded

username=ls&password=12345

###
